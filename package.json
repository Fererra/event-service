{
  "name": "auth-app",
  "version": "1.0.0",
  "scripts": {
    "dev": "node --env-file=.env -r ts-node/register src/app.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/app.js",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "docker:restart": "docker compose restart app",
    "db:up": "docker compose up postgres -d",
    "db:down": "docker compose stop postgres",
    "db:test:up": "docker compose up postgres-test -d",
    "db:test:down": "docker compose stop postgres-test",
    "docker:clean": "docker compose down -v --remove-orphans",
    "test": "jest --config test/jest.config.ts",
    "test:integration": "jest --config test/jest.integration.config.ts --runInBand",
    "test:all": "npm test && npm run test:integration",
    "test:watch": "jest --config test/jest.config.ts --watch",
    "test:coverage": "jest --config test/jest.config.ts --coverage"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "fastify": "^5.0.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^30.3.0",
    "prettier": "^3.3.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
